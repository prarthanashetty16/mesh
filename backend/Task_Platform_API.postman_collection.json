{
  "info": {
    "name": "Task Sharing Platform API",
    "description": "Complete API collection for task sharing platform backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"area_id\": 1,\n  \"address_line\": \"123 Main Street\",\n  \"landmark\": \"Near Park\",\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/user/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"address_line\": \"New Address\",\n  \"landmark\": \"Near School\",\n  \"latitude\": 12.9700,\n  \"longitude\": 77.6000\n}"
            },
            "url": "{{base_url}}/user/profile"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Home Cleaning\",\n  \"description\": \"Need cleaning\",\n  \"price\": 500,\n  \"deadline\": \"2024-05-01T10:00:00Z\",\n  \"area_id\": 1,\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}"
            },
            "url": "{{base_url}}/tasks"
          }
        },
        {
          "name": "Get Tasks",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tasks"
          }
        },
        {
          "name": "Nearby Tasks",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tasks/nearby?latitude=12.9716&longitude=77.5946"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/applications/1/apply"
          }
        },
        {
          "name": "My Applications",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/applications/my"
          }
        }
      ]
    },
    {
      "name": "Location",
      "item": [
        {
          "name": "Update Location",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": 12.9700,\n  \"longitude\": 77.6000\n}"
            },
            "url": "{{base_url}}/location/update"
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/wallet/balance"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Add Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Great work\"\n}"
            },
            "url": "{{base_url}}/reviews/task/1"
          }
        }
      ]
    }
  ]
}